# Copy to .env (next to docker-compose.yml) to override Docker run settings.
# All values have sensible defaults in docker-compose.yml; this file just
# documents what you can change.

# Host ports (kept off the dev ports 5173/8000 so both can run at once)
FRONTEND_PORT=3000
BACKEND_PORT=8080

# Ollama models (must already be pulled on the host)
VISION_MODEL=qwen2.5vl:7b
AGENT_MODEL=gemma4:latest
TEXT_MODEL=gemma4:latest

# Pipeline tuning
DEMO_MODE=false
MAX_AGENT_ITERATIONS=6
DEDUP_THRESHOLD=0.85
